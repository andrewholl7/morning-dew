# Copy this file to ".env" (same folder) and fill in your real values.
# The .env file is read automatically when you run main.py.
# NEVER share .env -- it holds your email login.

# Your Gmail address (the account that will SEND the alerts).
GMAIL_USER=you@gmail.com

# A Google "App Password" -- 16 characters, NOT your normal Gmail password.
# How to create one:
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create a password (name it "Tee Monitor"), copy the 16 characters.
#   4. Paste below (spaces are fine, or remove them -- either works).
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
